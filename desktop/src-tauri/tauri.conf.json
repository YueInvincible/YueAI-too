{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yue Desktop",
  "version": "0.1.0",
  "identifier": "com.yueai.desktop",
  "build": {
    "beforeDevCommand": "npm run preview",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Yue Desktop",
        "width": 380,
        "height": 760,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
